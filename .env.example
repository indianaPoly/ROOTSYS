# Copy this file to .env for local development.
# Never commit real secrets.

# Output root for local MVP bootstrap script.
ROOTSYS_MVP_OUT_DIR=/tmp/rootsys-mvp

# Example placeholders for external systems.
# Replace with local test values only.
ROOTSYS_API_KEY=replace-with-local-test-key
ROOTSYS_OAUTH_CLIENT_ID=replace-with-local-test-client-id
ROOTSYS_OAUTH_CLIENT_SECRET=replace-with-local-test-client-secret

# Optional database DSN placeholders.
ROOTSYS_POSTGRES_DSN=host=localhost user=app password=secret dbname=ops
ROOTSYS_MYSQL_DSN=mysql://app:secret@localhost:3306/ops
