{
  "name": "mysql-sample",
  "version": "v1",
  "driver": {
    "kind": "db",
    "db": {
      "kind": "mysql",
      "connection": "mysql://app:secret@localhost:3306/ops",
      "query": "SELECT * FROM defect_events",
      "pool": {
        "min_connections": 1,
        "max_connections": 10
      },
      "retry": {
        "max_attempts": 3,
        "base_delay_ms": 100,
        "max_delay_ms": 2000,
        "jitter_percent": 20
      }
    }
  },
  "payload_format": "json"
}
