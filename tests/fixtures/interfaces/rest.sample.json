{
  "name": "rest-sample",
  "version": "v1",
  "driver": {
    "kind": "rest",
    "rest": {
      "url": "https://api.example.com/events",
      "method": "GET",
      "headers": {
        "Accept": "application/json"
      },
      "auth": {
        "kind": "api_key",
        "api_key": {
          "in": "header",
          "name": "X-API-KEY",
          "value": "<token>"
        }
      },
      "timeout_ms": 5000,
      "retry": {
        "max_attempts": 3,
        "base_delay_ms": 100,
        "max_delay_ms": 2000,
        "jitter_percent": 20
      },
      "response_format": "json",
      "items_pointer": "/items"
    }
  },
  "payload_format": "json"
}
