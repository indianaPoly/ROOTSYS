{
  "name": "postgres-sample",
  "version": "v1",
  "driver": {
    "kind": "db",
    "db": {
      "kind": "postgres",
      "connection": "host=localhost user=app password=secret dbname=ops",
      "query": "SELECT * FROM defect_events",
      "postgres_tls_mode": "require",
      "pool": {
        "min_connections": 1,
        "max_connections": 10
      }
    }
  },
  "payload_format": "json"
}
