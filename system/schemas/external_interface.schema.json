{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rootsys.local/schemas/external_interface.schema.json",
  "title": "ROOTSYS ExternalInterface",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "driver"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "driver": {
      "$ref": "#/$defs/driverSpec"
    },
    "payload_format": {
      "$ref": "#/$defs/payloadFormat"
    },
    "record_id_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^/"
      },
      "uniqueItems": true
    },
    "required_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^/"
      },
      "uniqueItems": true
    },
    "record_id_policy": {
      "type": "string",
      "enum": [
        "strict",
        "hash_fallback"
      ]
    }
  },
  "$defs": {
    "payloadFormat": {
      "type": "string",
      "enum": [
        "json",
        "text",
        "binary",
        "unknown"
      ]
    },
    "driverKind": {
      "type": "string",
      "enum": [
        "jsonl",
        "text",
        "binary",
        "rest",
        "db",
        "stream"
      ]
    },
    "streamSourceKind": {
      "type": "string",
      "enum": [
        "kafka"
      ]
    },
    "streamStartOffset": {
      "type": "string",
      "enum": [
        "earliest",
        "latest"
      ]
    },
    "streamKafkaMode": {
      "type": "string",
      "enum": [
        "mvp_file",
        "live"
      ]
    },
    "dbKind": {
      "type": "string",
      "enum": [
        "sqlite",
        "postgres",
        "mysql"
      ]
    },
    "postgresTlsMode": {
      "type": "string",
      "enum": [
        "disable",
        "require"
      ]
    },
    "restAuthKind": {
      "type": "string",
      "enum": [
        "api_key",
        "oauth2_client_credentials"
      ]
    },
    "apiKeyLocation": {
      "type": "string",
      "enum": [
        "header",
        "query"
      ]
    },
    "restPaginationKind": {
      "type": "string",
      "enum": [
        "cursor",
        "page"
      ]
    },
    "retryConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "base_delay_ms": {
          "type": "integer",
          "minimum": 1
        },
        "max_delay_ms": {
          "type": "integer",
          "minimum": 1
        },
        "jitter_percent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "circuitBreakerConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "failure_threshold": {
          "type": "integer",
          "minimum": 1
        },
        "open_timeout_ms": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "dbPoolConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_connections": {
          "type": "integer",
          "minimum": 1
        },
        "max_connections": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "apiKeyAuth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in",
        "name",
        "value"
      ],
      "properties": {
        "in": {
          "$ref": "#/$defs/apiKeyLocation"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "oauth2ClientCredentials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "token_url",
        "client_id",
        "client_secret"
      ],
      "properties": {
        "token_url": {
          "type": "string",
          "minLength": 1
        },
        "client_id": {
          "type": "string",
          "minLength": 1
        },
        "client_secret": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string"
        }
      }
    },
    "restAuth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/restAuthKind"
        },
        "api_key": {
          "$ref": "#/$defs/apiKeyAuth"
        },
        "oauth2_client_credentials": {
          "$ref": "#/$defs/oauth2ClientCredentials"
        }
      }
    },
    "cursorPagination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cursor_param",
        "cursor_path"
      ],
      "properties": {
        "cursor_param": {
          "type": "string",
          "minLength": 1
        },
        "cursor_path": {
          "type": "string",
          "pattern": "^/"
        },
        "initial_cursor": {
          "type": "string"
        },
        "max_pages": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "pagePagination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_param",
        "page_size_param",
        "page_size"
      ],
      "properties": {
        "page_param": {
          "type": "string",
          "minLength": 1
        },
        "page_size_param": {
          "type": "string",
          "minLength": 1
        },
        "page_size": {
          "type": "integer",
          "minimum": 1
        },
        "initial_page": {
          "type": "integer",
          "minimum": 1
        },
        "max_pages": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "restPagination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/restPaginationKind"
        },
        "cursor": {
          "$ref": "#/$defs/cursorPagination"
        },
        "page": {
          "$ref": "#/$defs/pagePagination"
        }
      }
    },
    "restConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "body": {
          "type": "string"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "response_format": {
          "$ref": "#/$defs/payloadFormat"
        },
        "items_pointer": {
          "type": "string",
          "pattern": "^/"
        },
        "auth": {
          "$ref": "#/$defs/restAuth"
        },
        "pagination": {
          "$ref": "#/$defs/restPagination"
        },
        "retry": {
          "$ref": "#/$defs/retryConfig"
        },
        "circuit_breaker": {
          "$ref": "#/$defs/circuitBreakerConfig"
        }
      }
    },
    "dbConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "connection",
        "query"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/dbKind"
        },
        "connection": {
          "type": "string",
          "minLength": 1
        },
        "query": {
          "type": "string",
          "minLength": 1
        },
        "postgres_tls_mode": {
          "$ref": "#/$defs/postgresTlsMode"
        },
        "pool": {
          "$ref": "#/$defs/dbPoolConfig"
        },
        "retry": {
          "$ref": "#/$defs/retryConfig"
        },
        "circuit_breaker": {
          "$ref": "#/$defs/circuitBreakerConfig"
        }
      }
    },
    "kafkaConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "brokers",
        "topic",
        "group_id",
        "format"
      ],
      "properties": {
        "brokers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "topic": {
          "type": "string",
          "minLength": 1
        },
        "group_id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "$ref": "#/$defs/streamKafkaMode"
        },
        "format": {
          "$ref": "#/$defs/payloadFormat"
        },
        "max_batch_records": {
          "type": "integer",
          "minimum": 1
        },
        "poll_timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "start_offset": {
          "$ref": "#/$defs/streamStartOffset"
        },
        "checkpoint_file": {
          "type": "string",
          "minLength": 1
        },
        "mvp_input": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "mode"
            ],
            "properties": {
              "mode": {
                "const": "live"
              }
            }
          },
          "then": {},
          "else": {
            "required": [
              "mvp_input"
            ]
          }
        }
      ]
    },
    "streamConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "kafka"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/streamSourceKind"
        },
        "kafka": {
          "$ref": "#/$defs/kafkaConfig"
        }
      }
    },
    "driverSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/driverKind"
        },
        "input": {
          "type": "string"
        },
        "content_type": {
          "type": "string"
        },
        "filename": {
          "type": "string"
        },
        "rest": {
          "$ref": "#/$defs/restConfig"
        },
        "db": {
          "$ref": "#/$defs/dbConfig"
        },
        "stream": {
          "$ref": "#/$defs/streamConfig"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "rest"
              }
            }
          },
          "then": {
            "required": [
              "rest"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "db"
              }
            }
          },
          "then": {
            "required": [
              "db"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "stream"
              }
            }
          },
          "then": {
            "required": [
              "stream"
            ]
          }
        }
      ]
    }
  }
}
